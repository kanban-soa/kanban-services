# Server
GATEWAY_PORT=8080
NODE_ENV=development

# JWT — must match the secret used by workspace-service
JWT_SECRET=

# Upstream service URLs
AUTH_SERVICE_URL=http://localhost:9005
WORKSPACE_SERVICE_URL=http://localhost:9005
BOARD_SERVICE_URL=http://localhost:9003
NOTI_SERVICE_URL=http://localhost:9004
STATISTIC_SERVICE_URL=http://localhost:9002

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# CORS — comma-separated origins, use * for development
CORS_ORIGINS=http://localhost:3000

# Proxy
UPSTREAM_TIMEOUT_MS=10000

