# Server
GATEWAY_PORT=8080
NODE_ENV=development

# JWT — must match the secret used by workspace-service
# SECRET KEY JWT example
JWT_SECRET= ""
JWT_SECRET_KEY= ""

# Upstream service URLs
AUTH_SERVICE_URL=http://localhost:9001
WORKSPACE_SERVICE_URL=http://localhost:9005
BOARD_SERVICE_URL=http://localhost:9003
NOTI_SERVICE_URL=http://localhost:9004
STATISTIC_SERVICE_URL=http://localhost:9002

# Upstream service PORTS
AUTH_SERVICE_PORT=9001
WORKSPACE_SERVICE_PORT=9005
BOARD_SERVICE_PORT=9003
NOTI_SERVICE_PORT=9004
STATISTIC_SERVICE_PORT=9002
# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# CORS — comma-separated origins, use * for development
CORS_ORIGINS=http://localhost:3000

# Proxy
UPSTREAM_TIMEOUT_MS=10000

# URL CONNECT DATABASE
# Config: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
WORKSPACE_URL="postgresql://admin:admin@localhost:5432/workspace_db"
NOTI_URL="postgresql://admin:admin@localhost:5432/noti_db"
BOARD_URL="postgresql://admin:admin@localhost:5432/board_db"
AUTH_URL="postgresql://admin:admin@localhost:5432/auth_db"

AUTH_URL=""
AUTH_PORT=9001
# JWT expires in 7 days
JWT_SECRET="iiii"
JWT_EXPIRES_IN="7d"
# SMTP configuration for nodemailer
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=''